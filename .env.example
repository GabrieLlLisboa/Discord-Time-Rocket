# ─────────────────────────────────────────────
#  Arvenor Bot — Configurações
# ─────────────────────────────────────────────

DISCORD_TOKEN=

# Canal onde a mensagem de boas-vindas será enviada
WELCOME_CHANNEL_ID=

# Prefixo dos comandos (ex: !help, !ban...)
PREFIX=!

# Chave da API da Tracker Network (tracker.gg) — usada pelo !tracker
# Crie a sua em: https://tracker.gg/developers
TRN_API_KEY=
